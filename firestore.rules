rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    // Collection: users
    // Document ID: {userId}
    // Fields:
    //   - uid: string (required)
    //   - name: string (required)
    //   - email: string (optional)
    //   - language: string (enum: en, hi, ta, kn)
    //   - bloodGroup: string (optional)
    //   - emergencyContact: string (optional)
    //
    // Collection: users/{userId}/reminders
    // Document ID: {reminderId}
    // Fields:
    //   - medicineName: string (required)
    //   - time: string (required)
    //   - dosage: string
    //   - isActive: bool
    // ===============================================================

    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    // User Profile Rules
    match /users/{userId} {
      allow read: if isOwner(userId);
      allow create: if isOwner(userId) && isValidUser(request.resource.data);
      allow update: if isOwner(userId) && isValidUser(request.resource.data);
      
      match /reminders/{reminderId} {
        allow read: if isOwner(userId);
        allow write: if isOwner(userId);
      }
    }

    function isValidUser(data) {
      return data.uid == request.auth.uid &&
             data.name is string && data.name.size() > 0 && data.name.size() < 100;
    }
  }
}
